+"""In-memory vector store with cosine-similarity search."""
+
+from __future__ import annotations
+
+import math
+import pickle
+from dataclasses import dataclass
+from pathlib import Path
+from typing import TYPE_CHECKING
+
+if TYPE_CHECKING:
+    from local_rag.ingestion import Chunk
+
+
+@dataclass
+class SearchResult:
+    chunk_id: str
+    source: str
+    text: str
+    score: float
+
+
+def _cosine(a: list[float], b: list[float]) -> float:
+    dot = sum(x * y for x, y in zip(a, b, strict=False))
+    na = math.sqrt(sum(x * x for x in a)) or 1.0
+    nb = math.sqrt(sum(x * x for x in b)) or 1.0
+    return dot / (na * nb)
+
+
+class VectorStore:
+    """Simple in-memory store: add chunks + their embeddings, search by cosine similarity."""
+
+    def __init__(self) -> None:
+        self._ids: list[str] = []
+        self._sources: list[str] = []
+        self._texts: list[str] = []
+        self._vectors: list[list[float]] = []
+
+    def add(self, chunks: list[Chunk], embeddings: list[list[float]]) -> None:
+        """Add chunks and their pre-computed embeddings."""
+        if len(chunks) != len(embeddings):
+            raise ValueError("chunks and embeddings must have the same length")
+        for chunk, vec in zip(chunks, embeddings, strict=False):
+            self._ids.append(chunk.chunk_id)
+            self._sources.append(chunk.source)
+            self._texts.append(chunk.text)
+            self._vectors.append(vec)
+
+    def search(self, query_vec: list[float], top_k: int = 5) -> list[SearchResult]:
+        """Return the *top_k* most similar chunks."""
+        if not self._vectors:
+            return []
+        scores = [(i, _cosine(query_vec, v)) for i, v in enumerate(self._vectors)]
+        scores.sort(key=lambda x: x[1], reverse=True)
+        results = []
+        for i, score in scores[:top_k]:
+            results.append(
+                SearchResult(
+                    chunk_id=self._ids[i],
+                    source=self._sources[i],
+                    text=self._texts[i],
+                    score=score,
+                )
+            )
+        return results
+
+    def __len__(self) -> int:
+        return len(self._ids)
+
+    def save(self, path: str | Path) -> None:
+        """Persist the store to disk using pickle."""
+        path = Path(path)
+        path.parent.mkdir(parents=True, exist_ok=True)
+        data = {
+            "ids": self._ids,
+            "sources": self._sources,
+            "texts": self._texts,
+            "vectors": self._vectors,
+        }
+        with open(path, "wb") as f:
+            pickle.dump(data, f)
+
+    @classmethod
+    def load(cls, path: str | Path) -> VectorStore:
+        """Load a previously saved store from disk."""
+        path = Path(path)
+        if not path.exists():
+            raise FileNotFoundError(f"Vector store not found: {path}")
+        with open(path, "rb") as f:
+            data = pickle.load(f)
+        store = cls()
+        store._ids = data["ids"]
+        store._sources = data["sources"]
+        store._texts = data["texts"]
+        store._vectors = data["vectors"]
+        return store
+
+    def clear(self) -> None:
+        """Remove all entries from the store."""
+        self._ids = []
+        self._sources = []
+        self._texts = []
+        self._vectors = []
+
+    def merge(self, other: VectorStore) -> None:
+        """Merge another VectorStore into this one in-place."""
+        self._ids.extend(other._ids)
+        self._sources.extend(other._sources)
+        self._texts.extend(other._texts)
+        self._vectors.extend(other._vectors)
